{
  "name": "http_js",
  "version": "0.1.0",
  "description": "TypeScript utilities for HTTP APIs and microservices.",
  "license": "MIT",
  "type": "module",
  "engines": {
    "node": ">=24.0.0"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "clean": "rimraf dist",
    "format": "prettier --write \"{src,examples}/**/*.{ts,js,json,md}\" README.md",
    "format-check": "prettier --check \"{src,examples}/**/*.{ts,js,json,md}\" README.md",
    "lint": "eslint \"src/**/*.ts\"",
    "lint-fix": "eslint \"src/**/*.ts\" --fix",
    "precommit": "npm run lint && npm run format-check && npm run type-check && npm run test",
    "test": "jest --runInBand",
    "test-watch": "jest --watch",
    "type-check": "tsc --noEmit -p tsconfig.json"
  },
  "dependencies": {
    "@aws-sdk/client-secrets-manager": "^3.934.0",
    "pg": "^8.16.3"
  },
  "devDependencies": {
    "@types/pg": "^8.15.5",
    "@types/jest": "^30.0.0",
    "@types/node": "^24.10.1",
    "@typescript-eslint/eslint-plugin": "^8.47.0",
    "@typescript-eslint/parser": "^8.47.0",
    "eslint": "^9.39.1",
    "jest": "^30.2.0",
    "prettier": "^3.5.3",
    "rimraf": "^6.1.2",
    "ts-jest": "^29.4.5",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3"
  }
}
