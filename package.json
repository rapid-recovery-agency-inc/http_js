{
  "name": "@rapid-recovery-agency-inc/http_js",
  "version": "0.1.0",
  "description": "TypeScript utilities for HTTP APIs and microservices.",
  "license": "MIT",
  "type": "module",
  "engines": {
    "node": ">=24.0.0"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/cjs/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "bin": {
    "setup-environment": "dist/cli/setup-environment.js"
  },
  "publishConfig": {
    "registry": "https://npm.pkg.github.com/",
    "access": "restricted"
  },
  "scripts": {
    "precommit": "npm run lint && npm run format-check && npm run type-check && npm run test && npm run build",
    "prepublishOnly": "npm run build",
    "prepare": "husky",
    "build": "rm -rf dist && node scripts/build.mjs && tsc --emitDeclarationOnly && echo '{\"type\":\"commonjs\"}' > dist/cjs/package.json",
    "clean": "rimraf dist",
    "format": "prettier --write \"{src,examples}/**/*.{ts,js,json,md}\" README.md",
    "format-check": "prettier --check \"{src,examples}/**/*.{ts,js,json,md}\" README.md",
    "lint": "eslint \"src/**/*.ts\"",
    "lint-fix": "eslint \"src/**/*.ts\" --fix",
    "test": "jest --runInBand",
    "test-watch": "jest --watch",
    "type-check": "tsc --noEmit -p tsconfig.json",
    "smoke-test": "node scripts/smoke-test.mjs",
    "validate-build": "npm run build && npm run smoke-test"
  },
  "dependencies": {
    "@aws-sdk/client-secrets-manager": "^3.934.0",
    "dotenv": "^17.4.2",
    "morgan": "^1.10.1",
    "pg": "^8.16.3",
    "winston": "^3.19.0",
    "winston-transport": "^4.9.0"
  },
  "devDependencies": {
    "@rapid-recovery-agency-inc/eslint-plugin-rra": "^0.22.0",
    "@types/jest": "^30.0.0",
    "@types/morgan": "^1.9.10",
    "@types/node": "^24.10.1",
    "@types/pg": "^8.15.5",
    "@typescript-eslint/eslint-plugin": "^8.47.0",
    "@typescript-eslint/parser": "^8.47.0",
    "esbuild": "^0.28.1",
    "eslint": "^9.39.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-simple-import-sort": "^13.0.0",
    "husky": "^9.1.7",
    "jest": "^30.2.0",
    "prettier": "^3.5.3",
    "rimraf": "^6.1.2",
    "ts-jest": "^29.4.5",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3"
  },
  "peerDependencies": {
    "morgan": "^1.10.1"
  }
}
